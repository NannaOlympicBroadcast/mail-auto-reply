# IMAP settings (for receiving emails)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your@email.com
IMAP_PASSWORD=your_password
IMAP_MAILBOX=INBOX

# SMTP settings (for sending auto-replies)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password

# OpenAI API key for LLM-based reply generation
OPENAI_API_KEY=sk-...
# Optional: set to a custom OpenAI-compatible base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# GitHub username whose public repos are used as context
GITHUB_USERNAME=NannaOlympicBroadcast

# How often to check for new emails (seconds)
POLL_INTERVAL=60
